# Plantilla de variables de entorno. Copiá este archivo como ".env" y completá.
# El ".env" real y la key JSON NUNCA se commitean (están en .gitignore).

# --- Service account de SOLO LECTURA (rol Cloud Datastore Viewer) ---
# Opción A (cómoda en LOCAL): ruta a la key JSON descargada de GCP.
FIREBASE_SERVICE_ACCOUNT_PATH=./service-account.json

# Opción B (para DEPLOY en Netlify): el JSON completo en una sola línea.
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"sysadminpf", ...}

# Proyecto de Firebase (opcional; por defecto sysadminpf).
FIREBASE_PROJECT_ID=sysadminpf

# Login del mini-acceso. Se valida en el servidor. Solo se exige en DEPLOY;
# en `netlify dev` (local) NO se pide (bypass para probar sin fricción).
APP_USER=
APP_PASS=

# Origen permitido para CORS (en deploy, la URL del sitio).
ALLOWED_ORIGIN=*
